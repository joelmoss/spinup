{
  "name": "spinup",
  "displayName": "Spinup",
  "description": "Define and manage multiple concurrent processes from a sidebar via VS Code settings",
  "version": "0.1.0",
  "publisher": "joelmoss",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/joelmoss/spinup"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spinup",
          "title": "Spinup",
          "icon": "resources/icons/spinup.svg"
        }
      ]
    },
    "views": {
      "spinup": [
        {
          "id": "spinupCommands",
          "name": "Commands",
          "icon": "$(terminal)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "spinupCommands",
        "contents": "No commands configured.\n\nAdd commands to your workspace settings to get started.\n\n[Open Settings](command:spinup.openSettings)"
      }
    ],
    "commands": [
      {
        "command": "spinup.startAll",
        "title": "Start All",
        "category": "Spinup",
        "icon": "$(play)"
      },
      {
        "command": "spinup.stopAll",
        "title": "Stop All",
        "category": "Spinup",
        "icon": "$(debug-stop)"
      },
      {
        "command": "spinup.restartAll",
        "title": "Restart All",
        "category": "Spinup",
        "icon": "$(debug-restart)"
      },
      {
        "command": "spinup.start",
        "title": "Start",
        "category": "Spinup",
        "icon": "$(play)"
      },
      {
        "command": "spinup.stop",
        "title": "Stop",
        "category": "Spinup",
        "icon": "$(debug-stop)"
      },
      {
        "command": "spinup.restart",
        "title": "Restart",
        "category": "Spinup",
        "icon": "$(debug-restart)"
      },
      {
        "command": "spinup.clear",
        "title": "Clear Terminal",
        "category": "Spinup"
      },
      {
        "command": "spinup.openTerminal",
        "title": "Show Terminal",
        "category": "Spinup",
        "icon": "$(terminal)"
      },
      {
        "command": "spinup.toggleStartStop",
        "title": "Toggle Start/Stop",
        "category": "Spinup"
      },
      {
        "command": "spinup.startOrShowTerminal",
        "title": "Start or Show Terminal",
        "category": "Spinup"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "spinup.startAll",
          "when": "view == spinupCommands && spinup.hasCommands",
          "group": "navigation@1"
        },
        {
          "command": "spinup.stopAll",
          "when": "view == spinupCommands && spinup.hasCommands",
          "group": "navigation@2"
        },
        {
          "command": "spinup.restartAll",
          "when": "view == spinupCommands && spinup.hasCommands",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "spinup.start",
          "when": "view == spinupCommands && viewItem == stopped || view == spinupCommands && viewItem == errored",
          "group": "inline@1"
        },
        {
          "command": "spinup.stop",
          "when": "view == spinupCommands && viewItem == running",
          "group": "inline@1"
        },
        {
          "command": "spinup.restart",
          "when": "view == spinupCommands && viewItem == running",
          "group": "inline@2"
        },
        {
          "command": "spinup.openTerminal",
          "when": "view == spinupCommands && viewItem == running",
          "group": "inline@3"
        },
        {
          "command": "spinup.start",
          "when": "view == spinupCommands && viewItem == stopped || view == spinupCommands && viewItem == errored",
          "group": "command@1"
        },
        {
          "command": "spinup.stop",
          "when": "view == spinupCommands && viewItem == running",
          "group": "command@1"
        },
        {
          "command": "spinup.restart",
          "when": "view == spinupCommands && viewItem == running",
          "group": "command@2"
        },
        {
          "command": "spinup.clear",
          "when": "view == spinupCommands",
          "group": "command@3"
        },
        {
          "command": "spinup.openTerminal",
          "when": "view == spinupCommands",
          "group": "command@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "spinup.startAll",
        "key": "cmd+shift+s",
        "when": "view == spinupCommands"
      },
      {
        "command": "spinup.stopAll",
        "key": "cmd+shift+q",
        "when": "view == spinupCommands"
      },
      {
        "command": "spinup.toggleStartStop",
        "key": "s",
        "when": "focusedView == spinupCommands && listFocus"
      },
      {
        "command": "spinup.restart",
        "key": "r",
        "when": "focusedView == spinupCommands && listFocus"
      },
      {
        "command": "spinup.startOrShowTerminal",
        "key": "enter",
        "when": "focusedView == spinupCommands && listFocus"
      }
    ],
    "configuration": {
      "title": "Spinup",
      "properties": {
        "spinup.commands": {
          "type": "object",
          "default": {},
          "description": "Map of command names to their configuration",
          "additionalProperties": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {
                "type": "string",
                "description": "The shell command to execute"
              },
              "autostart": {
                "type": "boolean",
                "default": true,
                "description": "Whether to start this command automatically on activation"
              },
              "autoRestart": {
                "type": "boolean",
                "default": false,
                "description": "Whether to restart this command on crash with exponential backoff"
              },
              "interactive": {
                "type": "boolean",
                "default": false,
                "description": "Whether this command requires interactive terminal input"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory relative to workspace root"
              },
              "env": {
                "type": "object",
                "description": "Environment variables for this command",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "watch": {
                "type": "array",
                "description": "Glob patterns of files to watch — restarts command on change",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint src --ext js",
    "test": "node ./src/test/runTests.js"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.3.8",
    "mocha": "^10.2.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
